// Генетический код лука
// Семантика:
/// Тип:
///     <Ген>: [Условие активации](Радиус) {Отключаемые морфогены}

// Клетка зародышевой линии
// При создании новой клетки геном самой первой в списке используется по умолчанию
stem:
    // M0 - условие, морфоген M0 активен
    // M1 - условие, морфоген M1 НЕ активен
    // n(6) - условие, количество соседей равно 6
    M0: [M0 !M1 n(6)] {}
    // По умолчнаию клетки не делятся
    D: false
root:
    ...
skin:
    ...
blades:
    ...
